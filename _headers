# Cache headers for static hosts that support `_headers` (Cloudflare Pages, Netlify).
# GitHub Pages ignores this file; use a CDN/proxy in front if you need custom cache there.

/assets/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/css/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/js/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
